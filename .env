# Environment Variables Configuration
# NOTE: All sensitive credentials are now managed via Netlify Environment Variables
# Do NOT add real credentials here - use Netlify Dashboard instead

# Test Mode - Set to true only for MQTT testing without Firestore
VITE_TEST_MODE=false

# Netlify Environment Variables to set:
# - GEMINI_API_KEY: Google Gemini AI API key (server-side)
# - VITE_MQTT_USER: MQTT broker username (for APK builds)
# - VITE_MQTT_PASS: MQTT broker password (for APK builds)
