# ═══════════════════════════════════════════════════════════════════════════
# HydroSync Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# IMPORTANT: This file is for reference only. DO NOT store real API keys here!
# Set these variables in your deployment platform's environment settings:
#
# FOR NETLIFY:
#   Go to Site Settings > Build & Deploy > Environment Variables
#   Add each variable below with your actual values
#
# FOR LOCAL DEVELOPMENT:
#   Create a .env file (not tracked by git) with your actual values
#
# ═══════════════════════════════════════════════════════════════════════════

# ── AI CHATBOT (Required for AI features) ──────────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── MQTT CONFIGURATION (For real-time device communication) ────────────────
# These are OPTIONAL - devices can have individual MQTT credentials
# Set these for global MQTT fallback credentials
VITE_MQTT_USER=your_mqtt_username
VITE_MQTT_PASS=your_mqtt_password

# ── FIREBASE CONFIGURATION ─────────────────────────────────────────────────
# These are already configured in src/firebase.ts
# Only needed if you want to override the defaults
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id

# ── APP URL (Optional) ─────────────────────────────────────────────────────
# Used for self-referential links, OAuth callbacks
APP_URL=https://your-app.netlify.app
